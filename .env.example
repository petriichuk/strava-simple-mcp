# Strava API app credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Seed refresh token from a one-time OAuth with scope activity:read_all
STRAVA_REFRESH_TOKEN=your_initial_refresh_token

# Secret segment in the public connector URL (treat like a password).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 24 characters; server refuses to start otherwise.
MCP_PATH_SECRET=change_me_to_a_long_random_string_at_least_24_chars

# Optional: where the SQLite cache lives
COACH_DB_PATH=coach.db

# Optional: network bind. Defaults are loopback-only on port 8080.
# To bind a non-loopback interface (e.g., on EC2), set MCP_HOST and opt in:
# MCP_HOST=0.0.0.0
# MCP_PORT=8080
# MCP_ALLOW_PUBLIC_BIND=1

# Optional: MCP SDK DNS-rebinding-protection allow-list. Default rejects any
# Host header that isn't 127.0.0.1 / localhost (returns 421). When serving
# through a tunnel (cloudflared, ngrok) or on an EC2 domain, set this:
#   MCP_ALLOWED_HOSTS=*                      # disable the check entirely
#   MCP_ALLOWED_HOSTS=your-domain.com        # one host (with or without :port)
#   MCP_ALLOWED_HOSTS=host-a.com,host-b.com  # comma-separated list
